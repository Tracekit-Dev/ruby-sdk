# TraceKit Configuration
TRACEKIT_ENABLED=true
TRACEKIT_API_KEY=api-key-placeholder
TRACEKIT_ENDPOINT=app.tracekit.dev
TRACEKIT_SERVICE_NAME=ruby-test-app
TRACEKIT_ENVIRONMENT=development
TRACEKIT_SERVICE_VERSION=1.0.0

# Code Monitoring
TRACEKIT_CODE_MONITORING=true

# LLM API Keys
ANTHROPIC_API_KEY=api-key-placeholder
OPENAI_API_KEY=api-key-placeholder

# LLM Content Capture
TRACEKIT_LLM_CAPTURE_CONTENT=true
